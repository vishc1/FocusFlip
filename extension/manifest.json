{
  "manifest_version": 3,
  "name": "FocusFlip",
  "version": "2.0.0",
  "description": "Camera detects when you sit down. OpenAI scores the page. Bad page? Auto-redirect.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.openai.com/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusFlip"
  }
}
